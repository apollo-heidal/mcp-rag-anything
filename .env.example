LLM_API_BASE=http://localhost:12434/engines/v1
LLM_MODEL=docker.io/local/qwen3.5-2b-vlm:latest
VISION_API_BASE=http://localhost:12434/engines/v1
VISION_MODEL=docker.io/local/qwen3.5-2b-vlm:latest
VISION_API_KEY=docker-model-runner
VISION_REQUIRED=true
EMBEDDING_MODEL=ai/mxbai-embed-large
EMBEDDING_DIM=1024
OPENAI_API_KEY=docker-model-runner
APP_BASE_URL=http://localhost:8000
RAG_SESSION_SECRET=change-me-for-production
UI_SESSION_TTL_SECONDS=900
UPLOAD_LINK_TTL_SECONDS=900
RAG_WORKING_DIR=/var/home/YOUR_USER/.rag_storage
VIDEO_ENGINE_ENABLED=true
VIDEO_SEGMENT_LENGTH=30
AUDIO_TRANSCRIBE_MODEL=openai/whisper-small
WHISPER_API_BASE=http://whisper:8080
# Vector backend: "milvus" (default) or "nano" (file-based NanoVectorDB)
VECTOR_BACKEND=milvus
MILVUS_URI=http://milvus:19530
MILVUS_DB_NAME=default
ATTU_URL=http://localhost:3000
